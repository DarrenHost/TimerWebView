<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Bootstrap 风格主题 -->
    <style name="Theme.TimerWebView" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- 主色 - Bootstrap Primary -->
        <item name="colorPrimary">@color/bootstrap_primary</item>
        <item name="colorPrimaryVariant">@color/bootstrap_primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorAccent">@color/bootstrap_primary</item>
        
        <!-- ActionBar 文字颜色 -->
        <item name="android:textColorPrimary">@color/white</item>
        <item name="actionMenuTextColor">@color/white</item>
        
        <!-- 输入框文字颜色 -->
        <item name="editTextColor">@color/bootstrap_dark</item>
        <item name="android:editTextColor">@color/bootstrap_dark</item>
        
        <!-- 按钮样式 - Bootstrap 风格 -->
        <item name="materialButtonStyle">@style/BootstrapButton</item>
    </style>
    
    <!-- Bootstrap 风格按钮 -->
    <style name="BootstrapButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/bootstrap_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">6dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <!-- Bootstrap 风格 Outline 按钮 -->
    <style name="BootstrapButton.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/bootstrap_primary</item>
        <item name="android:textColor">@color/bootstrap_primary</item>
        <item name="cornerRadius">6dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
    </style>
    
    <!-- Bootstrap 风格输入框 -->
    <style name="BootstrapTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/bootstrap_primary</item>
        <item name="boxCornerRadiusTopStart">6dp</item>
        <item name="boxCornerRadiusTopEnd">6dp</item>
        <item name="boxCornerRadiusBottomStart">6dp</item>
        <item name="boxCornerRadiusBottomEnd">6dp</item>
        <item name="hintTextColor">@color/gray</item>
    </style>
</resources>
